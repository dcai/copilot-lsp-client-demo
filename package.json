{
  "name": "copilot-lsp-stats",
  "version": "1.0.0",
  "description": "CLI harness for testing @github/copilot-language-server with TypeScript files",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "auth:signin": "bun src/cli.ts auth:signin",
    "auth:signout": "bun src/cli.ts auth:signout",
    "auth:status": "bun src/cli.ts auth:status",
    "complete": "bun src/cli.ts complete"
  },
  "keywords": [
    "copilot",
    "lsp",
    "typescript",
    "neovim"
  ],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "engines": {
    "node": ">=20.8"
  },
  "dependencies": {
    "@github/copilot-language-server": "^1.467.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}
